{% doc %}
  Renders the product title block for a product page.

  Context:
  - Requires the parent section to provide the global `product` and `block` objects.
  - Intended for product-detail sections only.
{% enddoc %}

{% schema %}
{
  "name": "Product Title",
  "settings": [],
  "presets": [
    {
      "name": "Product Title"
    }
  ]
}
{% endschema %}

<div class="product__title" {{ block.shopify_attributes }}>
  <h1>{{ product.title | escape }}</h1>
  <a href="{{ product.url }}" class="product__title">
    <h2 class="h1">
      {{ product.title | escape }}
    </h2>
  </a>
</div>

{% stylesheet %}
  .product__title {
    word-break: break-word;
    margin-bottom: 1.5rem;
  }

  .product__title > * {
    margin: 0;
  }

  .product__title > a {
    display: none;
  }
{% endstylesheet %}
