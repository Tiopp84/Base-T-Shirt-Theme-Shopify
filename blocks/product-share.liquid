{% doc %}
  Renders a product share button block.

  Context:
  - Requires the parent section to provide the global `product`, `request`, and `block` objects.
  - Uses the selected variant URL when available and falls back to the product URL.
  - Intended for product-detail sections only.
{% enddoc %}

{% schema %}
{
  "name": "t:sections.main-product.blocks.share.name",
  "settings": [
    {
      "type": "text",
      "id": "share_label",
      "label": "t:sections.main-product.blocks.share.settings.text.label",
      "default": "t:sections.main-product.blocks.share.settings.text.default"
    }
  ],
  "presets": [
    {
      "name": "t:sections.main-product.blocks.share.name"
    }
  ]
}
{% endschema %}

{% liquid
  assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin
  render 'share-button', block: block, share_link: share_url
%}
