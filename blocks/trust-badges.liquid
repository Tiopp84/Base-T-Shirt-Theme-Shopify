{% doc %}
  Renders trust badges as a theme block.
{% enddoc %}

<div class="trust-badges trust-badges-{{ block.id }}" {{ block.shopify_attributes }}>
  {%- if block.settings.show_secure_payment -%}
  <div class="trust-badge">
    {% render 'icon-shield' %}
    <span>{{ 'products.product.secure_payment' | t }}</span>
  </div>
  {%- endif -%}
  {%- if block.settings.show_returns -%}
  <div class="trust-badge">
    {% render 'icon-return' %}
    <span>{{ 'products.product.easy_returns' | t }}</span>
  </div>
  {%- endif -%}
  {%- if block.settings.show_shipping -%}
  <div class="trust-badge">
    {% render 'icon-shipping' %}
    <span>{{ 'products.product.free_shipping' | t }}</span>
  </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    column-gap: 2.4rem;
    row-gap: 1.6rem;
    margin: 3rem 0;
    padding: 2.4rem 0;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
  }
  
  .trust-badge {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: 0.05rem;
    color: rgba(var(--color-foreground), 0.8);
    transition: color var(--duration-short) ease, transform var(--duration-short) ease;
  }
  
  .trust-badge:hover {
    color: rgba(var(--color-foreground), 1);
    transform: translateY(-2px);
  }
  
  .trust-badge svg {
    width: 2.4rem;
    height: 2.4rem;
    color: rgba(var(--color-foreground), 0.9);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main-product.blocks.trust_badges.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_secure_payment",
      "label": "t:sections.main-product.blocks.trust_badges.settings.show_secure_payment.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_returns",
      "label": "t:sections.main-product.blocks.trust_badges.settings.show_returns.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_shipping",
      "label": "t:sections.main-product.blocks.trust_badges.settings.show_shipping.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.main-product.blocks.trust_badges.name"
    }
  ]
}
{% endschema %}
