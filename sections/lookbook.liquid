{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="lookbook color-{{ section.settings.color_scheme }} gradient">
  <div class="lookbook__inner page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <div class="lookbook__header">
        <p class="lookbook__eyebrow caption-with-letter-spacing">{{ 'sections.lookbook.eyebrow' | t }}</p>
        <h2 class="lookbook__heading h1">{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="lookbook__image-container">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 2200
          | image_tag:
            widths: '750, 1100, 1500, 1780, 2200',
            sizes: '(min-width: 990px) 1100px, calc(100vw - 3rem)',
            loading: 'lazy',
            class: 'lookbook__image'
        }}
      {%- else -%}
        {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg lookbook__image' }}
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.settings.product != blank -%}
          <div
            class="lookbook__pin"
            style="top: {{ block.settings.top }}%; left: {{ block.settings.left }}%;"
            {{ block.shopify_attributes }}
          >
            <button class="lookbook__pin-button" aria-label="{{ 'sections.lookbook.view_product' | t: product_name: block.settings.product.title | escape }}">
              <span class="lookbook__pin-icon"></span>
            </button>
            <div class="lookbook__product-card">
              <a href="{{ block.settings.product.url }}" class="lookbook__product-link">
                <span class="lookbook__product-image">
                  {%- if block.settings.product.featured_image != blank -%}
                    {{
                      block.settings.product.featured_image
                      | image_url: width: 220
                      | image_tag:
                        widths: '110, 165, 220',
                        sizes: '7.2rem',
                        loading: 'lazy',
                        alt: block.settings.product.title
                    }}
                  {%- else -%}
                    {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </span>
                <span class="lookbook__product-info">
                  <span class="lookbook__product-title">{{ block.settings.product.title | escape }}</span>
                  <span class="lookbook__product-price">{{ block.settings.product.price | money }}</span>
                </span>
              </a>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .lookbook__header {
    display: grid;
    gap: 1rem;
    max-width: 68rem;
    margin: 0 0 2.8rem;
  }

  .lookbook__eyebrow,
  .lookbook__heading {
    margin: 0;
  }

  .lookbook__eyebrow {
    color: rgba(var(--color-foreground), 0.72);
  }

  .lookbook__image-container {
    position: relative;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  }

  .lookbook__image-container::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 45%, rgba(0, 0, 0, 0.18));
    pointer-events: none;
  }

  .lookbook__image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    object-fit: cover;
  }

  .lookbook__image.placeholder-svg {
    min-height: 42rem;
    background: rgba(var(--color-foreground), 0.05);
  }

  .lookbook__pin {
    position: absolute;
    z-index: 2;
    transform: translate(-50%, -50%);
  }

  .lookbook__pin-button {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.8rem;
    height: 3.8rem;
    padding: 0;
    border: 0.1rem solid rgba(255, 255, 255, 0.72);
    border-radius: 50%;
    color: rgb(var(--color-foreground));
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.16);
    cursor: pointer;
    transition: transform var(--theme-transition-fast, 180ms ease), box-shadow var(--theme-transition-fast, 180ms ease);
  }

  .lookbook__pin-button:hover,
  .lookbook__pin-button:focus-visible {
    transform: scale(1.08);
    box-shadow: 0 1.2rem 3.6rem rgba(0, 0, 0, 0.2);
  }

  .lookbook__pin-button:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.85);
    outline-offset: 0.3rem;
  }

  .lookbook__pin-icon {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: rgb(var(--color-foreground));
  }

  .lookbook__pin-button::after {
    content: '';
    position: absolute;
    inset: -0.5rem;
    border: 0.1rem solid rgba(255, 255, 255, 0.7);
    border-radius: 50%;
    animation: lookbook-pulse 2.4s infinite cubic-bezier(0.66, 0, 0, 1);
  }

  @keyframes lookbook-pulse {
    to {
      opacity: 0;
      transform: scale(1.8);
    }
  }

  .lookbook__product-card {
    position: absolute;
    bottom: calc(100% + 1.4rem);
    left: 50%;
    width: min(28rem, 78vw);
    padding: 1rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    background: rgb(var(--color-background));
    box-shadow: 0 1.6rem 4.8rem rgba(0, 0, 0, 0.18);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateX(-50%) translateY(0.8rem);
    transition:
      opacity var(--theme-transition-fast, 180ms ease),
      transform var(--theme-transition-fast, 180ms ease),
      visibility var(--theme-transition-fast, 180ms ease);
  }

  .lookbook__pin:hover .lookbook__product-card,
  .lookbook__pin:focus-within .lookbook__product-card {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%);
  }

  .lookbook__product-link {
    display: grid;
    grid-template-columns: 7.2rem 1fr;
    align-items: center;
    gap: 1.2rem;
    color: rgb(var(--color-foreground));
    text-decoration: none;
  }

  .lookbook__product-link:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.85);
    outline-offset: 0.3rem;
  }

  .lookbook__product-image {
    display: block;
    overflow: hidden;
    aspect-ratio: 1;
    background: rgba(var(--color-foreground), 0.04);
  }

  .lookbook__product-image img,
  .lookbook__product-image svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lookbook__product-info {
    display: grid;
    gap: 0.4rem;
    min-width: 0;
  }

  .lookbook__product-title {
    overflow-wrap: anywhere;
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .lookbook__product-price {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.72);
  }

  @media screen and (max-width: 749px) {
    .lookbook__image {
      aspect-ratio: 4 / 5;
    }

    .lookbook__pin-button {
      width: 3.4rem;
      height: 3.4rem;
    }

    .lookbook__product-card {
      width: min(24rem, 72vw);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lookbook__pin-button,
    .lookbook__product-card {
      transition: none;
    }

    .lookbook__pin-button::after {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.lookbook.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.lookbook.settings.image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.lookbook.settings.heading.label",
      "default": "t:sections.lookbook.settings.heading.default"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "product_pin",
      "name": "t:sections.lookbook.blocks.product_pin.name",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.lookbook.blocks.product_pin.settings.product.label"
        },
        {
          "type": "range",
          "id": "top",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "t:sections.lookbook.blocks.product_pin.settings.top.label",
          "default": 50
        },
        {
          "type": "range",
          "id": "left",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "t:sections.lookbook.blocks.product_pin.settings.left.label",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.lookbook.name"
    }
  ]
}
{% endschema %}
