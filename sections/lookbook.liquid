{%- liquid
  assign products_count = 0
  for block in section.blocks
    if block.settings.product != blank
      assign products_count = products_count | plus: 1
    endif
  endfor

  assign has_quick_add = false
  if section.settings.enable_quick_add and products_count > 0
    assign has_quick_add = true
  endif

  assign mobile_products_layout = section.settings.mobile_products_layout | default: 'swipe'
-%}

{%- if has_quick_add -%}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding .lookbook-shop__media {
    --lookbook-image-height: {{ section.settings.image_height }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<lookbook-shop class="lookbook-shop color-{{ section.settings.color_scheme }} gradient">
  <div class="lookbook-shop__inner page-width section-{{ section.id }}-padding">
    <div class="lookbook-shop__layout lookbook-shop__layout--{{ section.settings.desktop_media_width }} lookbook-shop__layout--desktop-image-{{ section.settings.desktop_image_position }} lookbook-shop__layout--mobile-{{ section.settings.mobile_layout }} lookbook-shop__layout--mobile-products-{{ mobile_products_layout }}">
      <div class="lookbook-shop__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1800
            | image_tag:
              widths: '550, 750, 990, 1200, 1500, 1800',
              sizes: '(min-width: 990px) 50vw, calc(100vw - 3rem)',
              loading: 'lazy',
              class: 'lookbook-shop__image'
          }}
        {%- else -%}
          {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg lookbook-shop__image' }}
        {%- endif -%}

        {%- assign pin_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            {%- assign pin_index = pin_index | plus: 1 -%}
            <a
              class="lookbook-shop__pin{% if pin_index == 1 %} is-active{% endif %}"
              href="#LookbookProduct-{{ section.id }}-{{ block.id }}"
              style="--pin-top: {{ block.settings.top }}%; --pin-left: {{ block.settings.left }}%;"
              aria-label="{{ 'sections.lookbook.view_product' | t: product_name: block.settings.product.title | escape }}"
              aria-controls="LookbookProduct-{{ section.id }}-{{ block.id }}"
              data-lookbook-index="{{ pin_index }}"
              {{ block.shopify_attributes }}
            >
              <span class="lookbook-shop__pin-number">{{ pin_index }}</span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="lookbook-shop__content">
        <div class="lookbook-shop__header">
          {%- if section.settings.eyebrow != blank -%}
            <p class="lookbook-shop__eyebrow caption-with-letter-spacing">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="lookbook-shop__heading {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="lookbook-shop__text rte">{{ section.settings.text }}</div>
          {%- endif -%}
        </div>

        <div class="lookbook-shop__products" role="list">
          {%- assign product_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- assign lookbook_product = block.settings.product -%}
            {%- if lookbook_product != blank -%}
              {%- liquid
                assign product_index = product_index | plus: 1
                assign selected_variant = lookbook_product.selected_or_first_available_variant
                assign first_option = lookbook_product.options_with_values | first
                assign form_id = 'lookbook-product-form-' | append: section.id | append: '-' | append: block.id
                assign product_image_alt = lookbook_product.featured_image.alt | default: lookbook_product.title | escape
              -%}

              <article
                id="LookbookProduct-{{ section.id }}-{{ block.id }}"
                class="lookbook-shop__product{% if product_index == 1 %} is-active{% endif %}"
                data-lookbook-index="{{ product_index }}"
                role="listitem"
              >
                <a class="lookbook-shop__product-media" href="{{ lookbook_product.url }}" aria-label="{{ lookbook_product.title | escape }}">
                  <span class="lookbook-shop__product-index">{{ product_index }}</span>
                  {%- if lookbook_product.featured_image != blank -%}
                    {{
                      lookbook_product.featured_image
                      | image_url: width: 260
                      | image_tag:
                        widths: '120, 180, 260',
                        sizes: '10rem',
                        loading: 'lazy',
                        alt: product_image_alt
                    }}
                  {%- else -%}
                    {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </a>

                <div class="lookbook-shop__product-details">
                  {%- if block.settings.badge != blank -%}
                    <p class="lookbook-shop__badge">{{ block.settings.badge | escape }}</p>
                  {%- endif -%}

                  <a href="{{ lookbook_product.url }}" class="lookbook-shop__product-title">
                    {{ lookbook_product.title | escape }}
                  </a>

                  <div class="lookbook-shop__product-price">
                    {%- render 'price', product: lookbook_product, use_variant: true -%}
                  </div>

                  {%- if first_option != blank and first_option.values.size > 1 -%}
                    <ul class="lookbook-shop__options" aria-label="{{ first_option.name | escape }}">
                      {%- for value in first_option.values limit: 5 -%}
                        <li class="lookbook-shop__option">{{ value | escape }}</li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>

                {%- if section.settings.enable_quick_add and lookbook_product.has_only_default_variant -%}
                  <product-form
                    class="lookbook-shop__quick-add"
                    data-section-id="{{ section.id }}"
                  >
                    <div class="product-form__error-message-wrapper" role="alert" hidden>
                      <span class="svg-wrapper">
                        {{- 'icon-error.svg' | inline_asset_content -}}
                      </span>
                      <span class="product-form__error-message"></span>
                    </div>

                    {%- form 'product',
                      lookbook_product,
                      id: form_id,
                      class: 'form lookbook-shop__form',
                      novalidate: 'novalidate',
                      data-type: 'add-to-cart-form'
                    -%}
                      <input
                        type="hidden"
                        name="id"
                        value="{{ selected_variant.id }}"
                        {% if selected_variant == null or selected_variant.available == false %}
                          disabled
                        {% endif %}
                        class="product-variant-id"
                      >
                      <button
                        type="submit"
                        name="add"
                        class="lookbook-shop__add-button"
                        aria-label="{{ 'sections.lookbook.add_to_cart' | t: product_name: lookbook_product.title | escape }}"
                        {% if selected_variant == null or selected_variant.available == false %}
                          disabled
                        {% endif %}
                      >
                        <span class="svg-wrapper">
                          {{- 'icon-cart.svg' | inline_asset_content -}}
                        </span>
                        <span class="visually-hidden">
                          {%- if selected_variant == null -%}
                            {{ 'products.product.unavailable' | t }}
                          {%- elsif selected_variant.available == false -%}
                            {{ 'products.product.sold_out' | t }}
                          {%- else -%}
                            {{ 'products.product.add_to_cart' | t }}
                          {%- endif -%}
                        </span>
                        {%- render 'loading-spinner' -%}
                      </button>
                    {%- endform -%}
                  </product-form>
                {%- elsif section.settings.enable_quick_add -%}
                  <a
                    href="{{ lookbook_product.url }}"
                    class="lookbook-shop__add-button lookbook-shop__choose-options"
                    aria-label="{{ 'products.product.choose_product_options' | t: product_name: lookbook_product.title | escape }}"
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-arrow.svg' | inline_asset_content -}}
                    </span>
                  </a>
                {%- endif -%}
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</lookbook-shop>

{% stylesheet %}
  .lookbook-shop {
    display: block;
  }

  .lookbook-shop__layout {
    display: grid;
    gap: 3rem;
    align-items: stretch;
  }

  .lookbook-shop__media {
    position: relative;
    min-height: min(var(--lookbook-image-height), 82vh);
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  }

  .lookbook-shop__media::after {
    content: '';
    position: absolute;
    inset: 1.2rem;
    z-index: 1;
    border: 0.1rem solid rgba(255, 255, 255, 0.42);
    pointer-events: none;
  }

  .lookbook-shop__image {
    display: block;
    width: 100%;
    height: 100%;
    min-height: min(var(--lookbook-image-height), 82vh);
    object-fit: cover;
  }

  .lookbook-shop__image.placeholder-svg {
    min-height: min(var(--lookbook-image-height), 82vh);
  }

  .lookbook-shop__pin {
    position: absolute;
    top: var(--pin-top);
    left: var(--pin-left);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.9rem;
    height: 3.9rem;
    border-radius: 50%;
    color: rgb(var(--color-button-text));
    background: rgb(var(--color-button));
    box-shadow: 0 0 0 1.4rem rgba(var(--color-button), 0.22);
    text-decoration: none;
    transform: translate(-50%, -50%);
    transition:
      box-shadow var(--theme-transition-fast, 180ms ease),
      transform var(--theme-transition-fast, 180ms ease),
      color var(--theme-transition-fast, 180ms ease),
      background var(--theme-transition-fast, 180ms ease);
  }

  .lookbook-shop__pin:hover,
  .lookbook-shop__pin:focus-visible,
  .lookbook-shop__pin.is-active {
    box-shadow: 0 0 0 1.8rem rgba(var(--color-button), 0.28);
    transform: translate(-50%, -50%) scale(1.06);
  }

  .lookbook-shop__pin.is-active {
    color: rgb(var(--color-button));
    background: rgb(var(--color-button-text));
  }

  .lookbook-shop__pin:focus-visible {
    outline: 0.2rem solid rgb(var(--color-foreground));
    outline-offset: 0.5rem;
  }

  .lookbook-shop__pin-number,
  .lookbook-shop__product-index {
    font-size: 1.4rem;
    line-height: 1;
  }

  .lookbook-shop__content {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .lookbook-shop__header {
    display: grid;
    gap: 1rem;
    margin-bottom: 3.6rem;
  }

  .lookbook-shop__eyebrow,
  .lookbook-shop__heading,
  .lookbook-shop__text,
  .lookbook-shop__badge {
    margin: 0;
  }

  .lookbook-shop__eyebrow {
    color: rgba(var(--color-foreground), 0.78);
  }

  .lookbook-shop__heading {
    line-height: 1.08;
  }

  .lookbook-shop__text {
    max-width: 62rem;
    color: rgba(var(--color-foreground), 0.82);
  }

  .lookbook-shop__products {
    display: grid;
    gap: 0;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }

  .lookbook-shop__product {
    display: grid;
    grid-template-columns: 10rem minmax(0, 1fr) auto;
    gap: 1.6rem;
    align-items: center;
    padding-block: 1.8rem;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.12);
    scroll-margin-block: 3rem;
    transition:
      background var(--theme-transition-fast, 180ms ease),
      padding-inline var(--theme-transition-fast, 180ms ease);
  }

  .lookbook-shop__product.is-active {
    margin-inline: -1.2rem;
    padding-inline: 1.2rem;
    background: rgba(var(--color-foreground), 0.045);
  }

  .lookbook-shop__product-media {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    color: rgb(var(--color-button-text));
    background: rgba(var(--color-foreground), 0.05);
    text-decoration: none;
  }

  .lookbook-shop__product-media img,
  .lookbook-shop__product-media svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--theme-transition-smooth, 360ms ease);
  }

  .lookbook-shop__product:hover .lookbook-shop__product-media img,
  .lookbook-shop__product:focus-within .lookbook-shop__product-media img,
  .lookbook-shop__product.is-active .lookbook-shop__product-media img {
    transform: scale(1.035);
  }

  .lookbook-shop__product-index {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: rgb(var(--color-button));
  }

  .lookbook-shop__product-details {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
  }

  .lookbook-shop__badge {
    justify-self: start;
    padding: 0.3rem 0.7rem;
    color: rgb(var(--color-button-text));
    background: rgb(var(--color-button));
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .lookbook-shop__product-title {
    color: rgb(var(--color-foreground));
    font-size: 1.4rem;
    line-height: 1.35;
    text-decoration: none;
  }

  .lookbook-shop__product-title:hover {
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }

  .lookbook-shop__product-price .price {
    font-size: 1.3rem;
    letter-spacing: 0;
  }

  .lookbook-shop__options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0.4rem 0 0;
    padding: 0;
    list-style: none;
  }

  .lookbook-shop__option {
    min-width: 2.4rem;
    padding: 0.3rem 0.6rem;
    background: rgba(var(--color-foreground), 0.05);
    color: rgba(var(--color-foreground), 0.82);
    font-size: 1.1rem;
    line-height: 1.2;
    text-align: center;
  }

  .lookbook-shop__quick-add {
    justify-self: end;
  }

  .lookbook-shop__form {
    margin: 0;
  }

  .lookbook-shop__add-button {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.4rem;
    height: 4.4rem;
    padding: 0;
    border: 0;
    color: rgb(var(--color-button-text));
    background: rgb(var(--color-button));
    cursor: pointer;
  }

  .lookbook-shop__add-button:hover:not([disabled]) {
    background: rgba(var(--color-button), 0.88);
  }

  .lookbook-shop__choose-options {
    justify-self: end;
    text-decoration: none;
  }

  .lookbook-shop__choose-options .svg-wrapper {
    transition: transform var(--theme-transition-fast, 180ms ease);
  }

  .lookbook-shop__choose-options:hover .svg-wrapper {
    transform: translateX(0.2rem);
  }

  .lookbook-shop__add-button:focus-visible {
    outline: 0.2rem solid rgb(var(--color-foreground));
    outline-offset: 0.3rem;
  }

  .lookbook-shop__add-button[disabled] {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .lookbook-shop__add-button .svg-wrapper {
    width: 2rem;
    height: 2rem;
  }

  .lookbook-shop__add-button .loading__spinner {
    position: absolute;
    inset: auto;
    width: 2rem;
  }

  .lookbook-shop__add-button.loading .svg-wrapper:not(.loading__spinner) {
    opacity: 0;
  }

  @media screen and (min-width: 990px) {
    .lookbook-shop__layout {
      grid-template-columns: minmax(0, 1fr) minmax(36rem, 0.95fr);
      gap: 4.8rem;
    }

    .lookbook-shop__layout--media-large {
      grid-template-columns: minmax(0, 1.1fr) minmax(34rem, 0.85fr);
    }

    .lookbook-shop__layout--media-small {
      grid-template-columns: minmax(0, 0.9fr) minmax(38rem, 1fr);
    }

    .lookbook-shop__layout--desktop-image-right .lookbook-shop__media {
      order: 2;
    }

    .lookbook-shop__layout--desktop-image-right .lookbook-shop__content {
      order: 1;
    }

    .lookbook-shop__content {
      justify-content: center;
      padding-block: 2rem;
    }
  }

  @media screen and (max-width: 989px) {
    .lookbook-shop__layout--mobile-content_first .lookbook-shop__content {
      order: -1;
    }

    .lookbook-shop__media,
    .lookbook-shop__image,
    .lookbook-shop__image.placeholder-svg {
      min-height: min(62rem, 120vw);
    }
  }

  @media screen and (max-width: 749px) {
    .lookbook-shop__layout {
      gap: 2.4rem;
    }

    .lookbook-shop__header {
      margin-bottom: 2.4rem;
    }

    .lookbook-shop__product {
      grid-template-columns: 8rem minmax(0, 1fr) auto;
      gap: 1.2rem;
    }

    .lookbook-shop__add-button {
      width: 4rem;
      height: 4rem;
    }

    .lookbook-shop__layout--mobile-products-swipe .lookbook-shop__products {
      grid-auto-flow: column;
      grid-auto-columns: minmax(27rem, 86%);
      gap: 1.2rem;
      overflow-x: auto;
      overscroll-behavior-inline: contain;
      padding-bottom: 1.2rem;
      border-top: 0;
      scroll-snap-type: inline mandatory;
      scrollbar-width: thin;
    }

    .lookbook-shop__layout--mobile-products-swipe .lookbook-shop__product {
      align-content: center;
      min-height: 14rem;
      padding: 1.2rem;
      border: 0.1rem solid rgba(var(--color-foreground), 0.12);
      scroll-snap-align: start;
    }

    .lookbook-shop__layout--mobile-products-swipe .lookbook-shop__product.is-active {
      margin-inline: 0;
      background: rgba(var(--color-foreground), 0.045);
    }
  }

  @media screen and (max-width: 480px) {
    .lookbook-shop__product {
      grid-template-columns: 7.2rem minmax(0, 1fr);
    }

    .lookbook-shop__quick-add {
      grid-column: 2;
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lookbook-shop__pin,
    .lookbook-shop__product,
    .lookbook-shop__product-media img,
    .lookbook-shop__choose-options .svg-wrapper {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('lookbook-shop')) {
    customElements.define(
      'lookbook-shop',
      class LookbookShop extends HTMLElement {
        connectedCallback() {
          if (this.dataset.initialized === 'true') return;
          this.dataset.initialized = 'true';

          this.pins = Array.from(this.querySelectorAll('.lookbook-shop__pin[data-lookbook-index]'));
          this.products = Array.from(this.querySelectorAll('.lookbook-shop__product[data-lookbook-index]'));

          const activate = (index) => {
            this.pins.forEach((pin) => pin.classList.toggle('is-active', pin.dataset.lookbookIndex === index));
            this.products.forEach((product) =>
              product.classList.toggle('is-active', product.dataset.lookbookIndex === index),
            );
          };

          this.pins.forEach((pin) => {
            ['pointerenter', 'focus', 'click'].forEach((eventName) => {
              pin.addEventListener(eventName, () => activate(pin.dataset.lookbookIndex));
            });
          });

          this.products.forEach((product) => {
            product.addEventListener('pointerenter', () => activate(product.dataset.lookbookIndex));
            product.addEventListener('focusin', () => activate(product.dataset.lookbookIndex));
          });
        }
      },
    );
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.lookbook.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.lookbook.settings.image.label"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.lookbook.settings.eyebrow.label",
      "default": "t:sections.lookbook.settings.eyebrow.default"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.lookbook.settings.heading.label",
      "default": "t:sections.lookbook.settings.heading.default"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.lookbook.settings.text.label",
      "default": "t:sections.lookbook.settings.text.default"
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "label": "t:sections.lookbook.settings.enable_quick_add.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.lookbook.settings.layout_header.content"
    },
    {
      "type": "select",
      "id": "desktop_media_width",
      "label": "t:sections.lookbook.settings.desktop_media_width.label",
      "options": [
        {
          "value": "media-small",
          "label": "t:sections.lookbook.settings.desktop_media_width.options__1.label"
        },
        {
          "value": "media-medium",
          "label": "t:sections.lookbook.settings.desktop_media_width.options__2.label"
        },
        {
          "value": "media-large",
          "label": "t:sections.lookbook.settings.desktop_media_width.options__3.label"
        }
      ],
      "default": "media-large"
    },
    {
      "type": "select",
      "id": "desktop_image_position",
      "label": "t:sections.lookbook.settings.desktop_image_position.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.lookbook.settings.desktop_image_position.options__1.label"
        },
        {
          "value": "right",
          "label": "t:sections.lookbook.settings.desktop_image_position.options__2.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "t:sections.lookbook.settings.mobile_layout.label",
      "options": [
        {
          "value": "image_first",
          "label": "t:sections.lookbook.settings.mobile_layout.options__1.label"
        },
        {
          "value": "content_first",
          "label": "t:sections.lookbook.settings.mobile_layout.options__2.label"
        }
      ],
      "default": "image_first"
    },
    {
      "type": "select",
      "id": "mobile_products_layout",
      "label": "t:sections.lookbook.settings.mobile_products_layout.label",
      "options": [
