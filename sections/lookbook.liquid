{% schema %}
{
  "name": "t:sections.lookbook.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.lookbook.settings.image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.lookbook.settings.heading.label",
      "default": "t:sections.lookbook.settings.heading.default"
    }
  ],
  "blocks": [
    {
      "type": "product_pin",
      "name": "t:sections.lookbook.blocks.product_pin.name",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.lookbook.blocks.product_pin.settings.product.label"
        },
        {
          "type": "range",
          "id": "top",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "t:sections.lookbook.blocks.product_pin.settings.top.label",
          "default": 50
        },
        {
          "type": "range",
          "id": "left",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "t:sections.lookbook.blocks.product_pin.settings.left.label",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.lookbook.name"
    }
  ]
}
{% endschema %}

<div class="lookbook page-width section-{{ section.id }}-padding">
  {%- if section.settings.heading != blank -%}
    <h2 class="lookbook__heading h2">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="lookbook__image-container">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'lookbook__image' }}
    {%- else -%}
      {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg lookbook__image' }}
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- if block.settings.product != blank -%}
        <div class="lookbook__pin" style="top: {{ block.settings.top }}%; left: {{ block.settings.left }}%;" {{ block.shopify_attributes }}>
          <button class="lookbook__pin-button" aria-label="{{ 'sections.lookbook.view_product' | t: product_name: block.settings.product.title | escape }}">
            <span class="lookbook__pin-icon"></span>
          </button>
          <div class="lookbook__product-card">
            <a href="{{ block.settings.product.url }}" class="lookbook__product-link">
              <div class="lookbook__product-image">
                <img src="{{ block.settings.product.featured_image | image_url: width: 150 }}" width="150" height="{{ 150 | divided_by: block.settings.product.featured_image.aspect_ratio | ceil }}" alt="{{ block.settings.product.title | escape }}">
              </div>
              <div class="lookbook__product-info">
                <span class="lookbook__product-title">{{ block.settings.product.title }}</span>
                <span class="lookbook__product-price">{{ block.settings.product.price | money }}</span>
              </div>
            </a>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .lookbook {
    margin-top: 5rem;
    margin-bottom: 5rem;
  }
  
  .lookbook__heading {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .lookbook__image-container {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
  }
  
  .lookbook__image {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .lookbook__pin {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 2;
  }
  
  .lookbook__pin-button {
    background: rgba(255, 255, 255, 0.95);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .lookbook__pin-button:hover {
    transform: scale(1.15);
  }
  
  .lookbook__pin-icon {
    display: block;
    width: 12px;
    height: 12px;
    background: #111;
    border-radius: 50%;
  }

  .lookbook__pin-button::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.8);
    animation: pulse 2s infinite cubic-bezier(0.66, 0, 0, 1);
  }

  @keyframes pulse {
    to {
      box-shadow: 0 0 0 20px rgba(255, 255, 255, 0);
    }
  }
  
  .lookbook__product-card {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-15px);
    background: #fff;
    padding: 1.2rem;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    width: 220px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), visibility 0.3s;
    pointer-events: none;
  }
  
  .lookbook__pin:hover .lookbook__product-card,
  .lookbook__pin:focus-within .lookbook__product-card {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(-25px);
    pointer-events: auto;
  }
  
  .lookbook__product-card::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 10px;
    border-style: solid;
    border-color: #fff transparent transparent transparent;
  }
  
  .lookbook__product-link {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
  }
  
  .lookbook__product-image img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    display: block;
  }
  
  .lookbook__product-title {
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.3;
    display: block;
  }
  
  .lookbook__product-price {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.75);
    font-weight: 500;
  }
{% endstylesheet %}
