{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="collection-tiles color-{{ section.settings.color_scheme }} gradient">
  <div class="collection-tiles__inner page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="collection-tiles__header">
        {%- if section.settings.subheading != blank -%}
          <p class="collection-tiles__eyebrow caption-with-letter-spacing">
            {{ section.settings.subheading | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="collection-tiles__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul
      class="collection-tiles__grid"
      style="--collection-tiles-columns: {{ section.settings.columns_desktop }};"
      role="list"
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign tile_collection = block.settings.collection
          assign tile_image = block.settings.image
          assign tile_title = block.settings.heading
          assign tile_url = block.settings.link
          assign cta_label = block.settings.cta_label

          if tile_image == blank and tile_collection.featured_image != blank
            assign tile_image = tile_collection.featured_image
          endif

          if tile_title == blank and tile_collection.title != blank
            assign tile_title = tile_collection.title
          endif

          if tile_url == blank and tile_collection.url != blank
            assign tile_url = tile_collection.url
          endif

          if tile_url == blank
            assign tile_url = routes.collections_url
          endif
        -%}
        <li
          class="collection-tiles__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {{ block.shopify_attributes }}
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <a class="collection-tiles__card" href="{{ tile_url }}">
            <span class="collection-tiles__media media">
              {%- if tile_image != blank -%}
                {{
                  tile_image
                  | image_url: width: 1400
                  | image_tag:
                    widths: '360, 535, 750, 1000, 1400',
                    sizes: '(min-width: 990px) calc((100vw - 10rem) / var(--collection-tiles-columns)), (min-width: 750px) calc((100vw - 6rem) / 2), calc(100vw - 3rem)',
                    loading: 'lazy',
                    class: 'collection-tiles__image'
                }}
              {%- else -%}
                {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg collection-tiles__image' }}
              {%- endif -%}
            </span>

            <span class="collection-tiles__content">
              <span class="collection-tiles__title">
                {%- if tile_title != blank -%}
                  {{ tile_title | escape }}
                {%- else -%}
                  {{ 'onboarding.collection_title' | t }}
                {%- endif -%}
              </span>
              {%- if section.settings.show_cta -%}
                <span class="collection-tiles__cta">
                  {%- if cta_label != blank -%}
                    {{ cta_label | escape }}
                  {%- else -%}
                    {{ 'sections.collection_tiles.shop_collection' | t }}
                  {%- endif -%}
                  <span class="svg-wrapper">
                    {{- 'icon-arrow.svg' | inline_asset_content -}}
                  </span>
                </span>
              {%- endif -%}
            </span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% stylesheet %}
  .collection-tiles__header {
    max-width: 72rem;
    margin-bottom: 2.8rem;
  }

  .collection-tiles__eyebrow {
    margin: 0 0 1rem;
    color: rgba(var(--color-foreground), 0.72);
  }

  .collection-tiles__heading {
    margin: 0;
  }

  .collection-tiles__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--theme-card-gap, 1.6rem);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .collection-tiles__card {
    position: relative;
    display: block;
    min-height: 100%;
    overflow: hidden;
    color: rgb(var(--color-background));
    text-decoration: none;
    background: rgba(var(--color-foreground), 0.06);
  }

  .collection-tiles__card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.58));
    pointer-events: none;
  }

  .collection-tiles__media {
    display: block;
    aspect-ratio: 4 / 5;
  }

  .collection-tiles__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--theme-transition-smooth, 400ms ease);
  }

  .collection-tiles__content {
    position: absolute;
    right: 1.6rem;
    bottom: 1.6rem;
    left: 1.6rem;
    z-index: 1;
    display: grid;
    gap: 0.8rem;
  }

  .collection-tiles__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 2.4vw, 3.4rem);
    line-height: 1.05;
    text-transform: uppercase;
  }

  .collection-tiles__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    width: fit-content;
    min-height: 3.2rem;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.08rem;
    text-transform: uppercase;
  }

  .collection-tiles__cta .svg-wrapper {
    width: 1.4rem;
  }

  .collection-tiles__card:hover .collection-tiles__image {
    transform: scale(1.035);
  }

  .collection-tiles__card:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.9);
    outline-offset: 0.3rem;
  }

  @media screen and (min-width: 750px) {
    .collection-tiles__grid {
      grid-template-columns: repeat(var(--collection-tiles-columns), minmax(0, 1fr));
    }

    .collection-tiles__content {
      right: 2rem;
      bottom: 2rem;
      left: 2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .collection-tiles__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-tiles__image {
      transition: none;
    }

    .collection-tiles__card:hover .collection-tiles__image {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collection-tiles.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "default": "t:sections.collection-tiles.settings.subheading.default",
      "label": "t:sections.collection-tiles.settings.subheading.label"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "t:sections.collection-tiles.settings.heading.default",
      "label": "t:sections.collection-tiles.settings.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "t:sections.collection-tiles.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "default": true,
      "label": "t:sections.collection-tiles.settings.show_cta.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "collection_tile",
      "name": "t:sections.collection-tiles.blocks.collection_tile.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection-tiles.blocks.collection_tile.settings.collection.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.collection-tiles.blocks.collection_tile.settings.image.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.collection-tiles.blocks.collection_tile.settings.heading.label"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "t:sections.collection-tiles.blocks.collection_tile.settings.cta_label.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.collection-tiles.blocks.collection_tile.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection-tiles.presets.name",
      "blocks": [
        {
          "type": "collection_tile"
        },
        {
          "type": "collection_tile"
        },
        {
          "type": "collection_tile"
        },
        {
          "type": "collection_tile"
        }
      ]
    }
  ]
}
{% endschema %}
