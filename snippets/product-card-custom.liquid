{% doc %}
  Renders a custom product card optimized for T-shirts (shows sizes on hover).
  
  @param {product} card_product - The product object
  @param {boolean} [show_secondary_image] - Show secondary image on hover
  @param {boolean} [show_vendor] - Show vendor
{% enddoc %}

<div class="card-wrapper product-card-wrapper underline-links-hover">
  <div class="card card--standard card--media" style="--ratio-percent: {{ 1 | divided_by: card_product.featured_media.aspect_ratio | times: 100 }}%;">
    <div class="card__inner">
      {%- if card_product.featured_media -%}
        <a href="{{ card_product.url }}" class="card__media">
          <div class="media media--transparent media--hover-effect">
            <img src="{{ card_product.featured_media | image_url: width: 533 }}"
                 alt="{{ card_product.featured_media.alt | escape }}"
                 class="motion-reduce"
                 loading="lazy"
                 width="{{ card_product.featured_media.width }}"
                 height="{{ card_product.featured_media.height }}">
            
            {%- if card_product.media[1] != nil and show_secondary_image -%}
              <img src="{{ card_product.media[1] | image_url: width: 533 }}"
                   alt="{{ card_product.media[1].alt | escape }}"
                   class="motion-reduce"
                   loading="lazy"
                   width="{{ card_product.media[1].width }}"
                   height="{{ card_product.media[1].height }}">
            {%- endif -%}
          </div>
        </a>
      {%- endif -%}

      <div class="card__quick-sizes">
        {%- for option in card_product.options_with_values -%}
          {%- assign downcased_option = option.name | downcase -%}
          {%- if downcased_option == 'size' or downcased_option == 'kích thước' -%}
            <div class="quick-sizes-list">
              {%- for value in option.values -%}
                <span class="quick-size-item">{{ value }}</span>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    <div class="card__content">
      <div class="card__information">
        <h3 class="card__heading h5">
          <a href="{{ card_product.url }}" class="full-unstyled-link">
            {{ card_product.title | escape }}
          </a>
        </h3>
        <div class="card-information">
          {%- if show_vendor -%}
            <span class="visually-hidden">{{ 'accessibility.vendor' | t }}</span>
            <div class="caption-with-letter-spacing light">{{ card_product.vendor }}</div>
          {%- endif -%}
          {% render 'price', product: card_product, price_class: '' %}
        </div>
      </div>
    </div>
  </div>

  {% stylesheet %}
    .product-card-wrapper .card__inner {
      position: relative;
      overflow: hidden;
      border-radius: var(--card-corner-radius);
    }

    .card__quick-sizes {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(4px);
      padding: 12px 10px;
      transform: translateY(100%);
      transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      display: flex;
      justify-content: center;
      z-index: 2;
    }

    .product-card-wrapper:hover .card__quick-sizes {
      transform: translateY(0);
    }

    .quick-sizes-list {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .quick-size-item {
      font-size: 1.1rem;
      font-weight: 600;
      padding: 4px 8px;
      border: 1px solid rgba(var(--color-foreground), 0.1);
      border-radius: 4px;
      color: rgb(var(--color-foreground));
      background: rgb(var(--color-background));
      transition: all 0.2s ease;
      cursor: pointer;
    }

    .quick-size-item:hover {
      background: rgb(var(--color-foreground));
      color: rgb(var(--color-background));
      transform: scale(1.05);
    }
  {% endstylesheet %}
</div>
