{% doc %}
  Renders a megamenu for the header.

  @param {object} [section] - Parent section object.

  @example
  {% render 'header-mega-menu' %}
{% enddoc %}

<nav class="header__inline-menu">
  <ul class="list-menu list-menu--inline" role="list">
    {%- for link in section.settings.menu.links -%}
      {%- liquid
        assign has_menu_cards = false
        if section.settings.show_discovery_cards
          if section.settings.menu_card_collections != blank
            assign has_menu_cards = true
          else
            if section.settings.menu_card_1_title != blank and section.settings.menu_card_1_link != blank
              assign has_menu_cards = true
            elsif section.settings.menu_card_2_title != blank and section.settings.menu_card_2_link != blank
              assign has_menu_cards = true
            elsif section.settings.menu_card_3_title != blank and section.settings.menu_card_3_link != blank
              assign has_menu_cards = true
            endif
          endif
        endif
      -%}
      <li>
        {%- if link.links != blank -%}
          <header-menu>
            <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu">
              <summary
                id="HeaderMenu-{{ link.handle }}"
                class="header__menu-item list-menu__item link focus-inset"
              >
                <span
                  {%- if link.child_active %}
                    class="header__active-menu-item"
                  {% endif %}
                >
                  {{- link.title | escape -}}
                </span>
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </summary>
              <div
                id="MegaMenu-Content-{{ forloop.index }}"
                class="mega-menu__content color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                tabindex="-1"
              >
                <div class="mega-menu__panel page-width{% if has_menu_cards %} mega-menu__panel--with-cards{% endif %}">
                  <ul
                    class="mega-menu__list{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                    role="list"
                  >
                    {%- for childlink in link.links -%}
                      <li>
                        <a
                          id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                          href="{{ childlink.url }}"
                          class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                          {% if childlink.current %}
                            aria-current="page"
                          {% endif %}
                        >
                          {{ childlink.title | escape }}
                        </a>
                        {%- if childlink.links != blank -%}
                          <ul class="list-unstyled" role="list">
                            {%- for grandchildlink in childlink.links -%}
                              <li>
                                <a
                                  id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                  href="{{ grandchildlink.url }}"
                                  class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                                  {% if grandchildlink.current %}
                                    aria-current="page"
                                  {% endif %}
                                >
                                  {{ grandchildlink.title | escape }}
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                  {%- if has_menu_cards -%}
                    <div class="mega-menu__cards">
                      {%- for menu_card_collection in section.settings.menu_card_collections limit: 3 -%}
                        {%- liquid
                          assign card_index = forloop.index
                          assign image_setting = 'menu_card_' | append: card_index | append: '_image'
                          assign title_setting = 'menu_card_' | append: card_index | append: '_title'
                          assign link_setting = 'menu_card_' | append: card_index | append: '_link'
                        -%}
                        {%- render 'collection-menu-card',
                          collection: menu_card_collection,
                          image: section.settings[image_setting],
                          title: section.settings[title_setting],
                          url: section.settings[link_setting],
                          class: 'collection-menu-card--mega'
                        -%}
                      {%- else -%}
                        {%- render 'collection-menu-card',
                          image: section.settings.menu_card_1_image,
                          title: section.settings.menu_card_1_title,
                          url: section.settings.menu_card_1_link,
                          class: 'collection-menu-card--mega'
                        -%}
                        {%- render 'collection-menu-card',
                          image: section.settings.menu_card_2_image,
                          title: section.settings.menu_card_2_title,
                          url: section.settings.menu_card_2_link,
                          class: 'collection-menu-card--mega'
                        -%}
                        {%- render 'collection-menu-card',
                          image: section.settings.menu_card_3_image,
                          title: section.settings.menu_card_3_title,
                          url: section.settings.menu_card_3_link,
                          class: 'collection-menu-card--mega'
                        -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </details>
          </header-menu>
        {%- else -%}
          <a
            id="HeaderMenu-{{ link.handle }}"
            href="{{ link.url }}"
            class="header__menu-item list-menu__item link link--text focus-inset"
            {% if link.current %}
              aria-current="page"
            {% endif %}
          >
            <span
              {%- if link.current %}
                class="header__active-menu-item"
              {% endif %}
            >
              {{- link.title | escape -}}
            </span>
          </a>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</nav>
